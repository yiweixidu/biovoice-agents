# BioVoice-Agents configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual keys.

# ── LLM (required for synthesis) ─────────────────────────────────────────────
# Option 1: OpenAI (cloud)
OPENAI_API_KEY=sk-...

# Option 2: Ollama (local, zero cost — run: ollama pull llama3.1:8b)
# LLM_TYPE=ollama
# LLM_MODEL=llama3.1:8b

# LLM settings (optional overrides)
# LLM_TYPE=openai
# LLM_MODEL=gpt-4o-mini
# LLM_TEMPERATURE=0.1

# ── PubMed (optional, but strongly recommended) ───────────────────────────────
# Free NCBI API key raises rate limit from 3 to 10 req/sec.
# Register at: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=
EMAIL=you@institution.edu

# ── Storage (optional, defaults shown) ───────────────────────────────────────
# COLLECTION_NAME=biovoice
# PERSIST_DIR=./data/vector_db
# CACHE_FILE=data/cache/articles.json
# OUTPUT_DIR=./output
